# 知识库路径
COFFEE_PATH=/app/coffee

# FAISS索引存储
FAISS_INDEX_PATH=/app/data/faiss_index.bin

# Ollama配置
OLLAMA_BASE_URL=http://192.168.31.147:56789
OLLAMA_MODEL=qwen2.5:7b-instruct

# RAG参数
TOP_K=3
SIMILARITY_THRESHOLD=0.5
EMBEDDING_MODEL=all-MiniLM-L6-v2

# 飞书配置（需填写）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
# 反馈卡片接收方（应用机器人 DM / 群）
# 优先 open_id（私聊给你），其次 chat_id（群）
FEISHU_ADMIN_OPEN_ID=
FEISHU_ADMIN_CHAT_ID=

# 日志配置
LOG_DIR=/app/logs
LOG_RETENTION_DAYS=7