# 知识库路径（容器内挂载点）
COFFEE_PATH=/app/coffee

# 宿主机咖啡知识库绝对路径（docker-compose 用，挂载到 /app/coffee）
COFFEE_HOST_PATH=./coffee

# FAISS索引存储
FAISS_INDEX_PATH=/app/data/faiss_index.bin

# Ollama配置（替换为你自己的 Ollama 服务地址）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# RAG参数
TOP_K=3
SIMILARITY_THRESHOLD=0.6
EMBEDDING_MODEL=moka-ai/m3e-base

# 飞书配置（需填写）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
# 反馈卡片接收方（应用机器人 DM / 群）
# 优先 open_id（私聊给你），其次 chat_id（群）
FEISHU_ADMIN_OPEN_ID=
FEISHU_ADMIN_CHAT_ID=

# 日志配置
LOG_DIR=/app/logs
LOG_RETENTION_DAYS=7